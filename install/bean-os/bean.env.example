# BEAN OS environment template
# Copy to /etc/bean/bean.env during install.

BEAN_HOME=/opt/bean
BEAN_REPO=/opt/bean/BEAN
BEAN_DATA=/var/lib/bean
BEAN_LOG_DIR=/var/log/bean
BEAN_DB_PATH=/var/lib/bean/bean_memory.db
BEAN_INBOX_DIR=/var/lib/bean/inbox
BEAN_RUNTIME_MODE=safe
BEAN_MOTION_ENABLED=0
BEAN_SENTIENCE_CLAIMED=0
BEAN_ALLOW_DREAM_ON_IDLE=0
BEAN_LLM_PROVIDER=stub
BEAN_LLM_MODEL=gpt-4o-mini

# Optional. Do not commit real secrets.
# OPENAI_API_KEY=
